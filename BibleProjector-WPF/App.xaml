<Application x:Class="BibleProjector_WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:BibleProjector_WPF"
             
             Exit="ProgramExit"
             DispatcherUnhandledException="ExitFromError"
             
             Startup="ProgramStart"
             >
    <!--테스트 진입 Startup="Startup_test"-->
    <!--프로그램 세팅 후 진입 Startup="ProgramStart"-->
    
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/ViewMapDictionary.xaml"/>
                <ResourceDictionary Source="/Resources/FontResourcesDictionary.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
    